## Example .env file (DO NOT commit your real secrets)
# Copy this file to `.env` and add your real API key locally.
# The `.env` file is ignored by git and kept local to your machine.

# Option A: API key
GEMINI_API_KEY="$env:GEMINI_API_KEY = 'AQ.Ab8RN6Li9JcUPvhg621OtWT5TWcZCY9DKD4xCO1YFo3QL182xw'"

# Option B: Service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
